{
  "name": "pear-ci-multisig",
  "version": "1.0.0",
  "main": "index.js",
  "type": "commonjs",
  "description": "Specialized subset of pear multisig CLI for CI pipelines",
  "license": "Apache-2.0",
  "files": [
    "lib/"
  ],
  "bin": "bin.js",
  "imports": {
    "fs": {
      "bare": "bare-fs",
      "default": "fs"
    },
    "path": {
      "bare": "bare-path",
      "default": "path"
    },
    "os": {
      "bare": "bare-os",
      "default": "os"
    }
  },
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test:gen": "brittle -r test/all.js test/*.test.js",
    "test": "npm run test:node",
    "test:node": "brittle-node --coverage test/all.js"
  },
  "devDependencies": {
    "@hyperswarm/testnet": "^3.1.4",
    "brittle": "^3.19.1",
    "lunte": "^1.3.0",
    "prettier": "^3.6.2",
    "prettier-config-holepunch": "^1.0.0"
  },
  "dependencies": {
    "bare-fs": "^4.6.0",
    "bare-os": "^3.8.7",
    "bare-path": "^3.0.0",
    "corestore": "^7.7.0",
    "hyper-multisig": "^2.1.0",
    "hypercore-crypto": "^3.6.1",
    "hypercore-id-encoding": "^1.3.0",
    "hypercore-sign": "^4.1.1",
    "hypercore-signing-request": "^5.1.1",
    "hyperdrive": "^13.3.1",
    "hyperswarm": "^4.16.0",
    "paparam": "^1.10.1",
    "pear-errors": "^1.0.1",
    "pear-link": "^4.2.1",
    "sodium-native": "^5.1.0",
    "z32": "^1.1.0"
  }
}
